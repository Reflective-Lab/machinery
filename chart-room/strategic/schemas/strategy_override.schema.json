{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://converge.zone/schemas/strategy_override.schema.json",
  "title": "Strategy STOP Override",
  "description": "Schema for overriding STOP outcomes at strategy gates. Only permitted for Class A (deterministic) violations. Requires explicit justification, bounded scope, and dual signatures for high-risk gates.",
  "type": "object",
  "required": ["gate_id", "stop_checks", "justification", "scope", "expiry", "signatures"],
  "properties": {
    "gate_id": {
      "type": "string",
      "enum": ["content-publish", "customer-commitment", "roadmap-promotion", "architecture-promotion", "funding-narrative"],
      "description": "Which strategy gate is being overridden"
    },
    "stop_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z]+\\.[a-z_]+\\.v\\d+$"
      },
      "description": "Check IDs being overridden (must all be Class A)"
    },
    "justification": {
      "type": "string",
      "minLength": 20,
      "description": "Why this override is necessary"
    },
    "scope": {
      "type": "string",
      "minLength": 10,
      "description": "Bounded scope of the override (what it applies to)"
    },
    "expiry": {
      "type": "string",
      "description": "Date or review trigger when override expires"
    },
    "compensating_controls": {
      "type": "string",
      "description": "Controls applied to mitigate risk. Required for high-risk gates."
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/signature"
      },
      "description": "Approver signatures. High-risk gates require 2 signatures."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of override"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "gate_id": {
            "enum": ["customer-commitment", "architecture-promotion", "funding-narrative"]
          }
        }
      },
      "then": {
        "properties": {
          "signatures": { "minItems": 2 }
        },
        "required": ["compensating_controls"]
      }
    }
  ],
  "$defs": {
    "signature": {
      "type": "object",
      "required": ["name", "role"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of approver"
        },
        "role": {
          "type": "string",
          "description": "Role of approver (gate-owner, counter-voice-owner, founder, legal-counsel, etc.)"
        }
      },
      "additionalProperties": false
    }
  }
}
