# Local Bedrock development: append this patch section to .cargo/config.toml
# (which IS checked in — keep the [net] section) to build against a local
# bedrock-platform checkout instead of the pinned release tag.
# Adjust the path to your reflective monorepo layout.
[patch."ssh://git@github.com/Reflective-Lab/bedrock-platform"]
converge-core = { path = "../../bedrock/foundation/converge/crates/core" }
converge-provider = { path = "../../bedrock/foundation/converge/crates/provider" }
converge-experience = { path = "../../bedrock/foundation/converge/crates/experience" }
converge-optimization = { path = "../../bedrock/foundation/converge/crates/optimization" }
converge-storage = { path = "../../bedrock/foundation/converge/crates/storage" }
helm-module-contracts = { path = "../../bedrock/foundation/helm/contracts/crates/helm-module-contracts" }
helm-event-substrate = { path = "../../bedrock/foundation/helm/contracts/crates/helm-event-substrate" }
