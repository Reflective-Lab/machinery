# EditorConfig helps maintain consistent coding styles for multiple developers
# working on the same project across various editors and IDEs.
# https://editorconfig.org

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = 100

# Justfile
[Justfile]
indent_style = tab
indent_size = 4

# Rust
[*.rs]
indent_style = space
indent_size = 4
max_line_length = 100

# TOML
[*.toml]
indent_style = space
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON
[*.json]
indent_style = space
indent_size = 2

# TypeScript/JavaScript
[*.{ts,tsx,js,jsx}]
indent_style = space
indent_size = 2
max_line_length = 100

# Shell
[*.{sh,bash,zsh}]
indent_style = space
indent_size = 2
