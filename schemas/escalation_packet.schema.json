{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://converge.zone/schemas/escalation_packet.schema.json",
  "title": "Escalation Packet",
  "description": "Schema for Extended team escalation packets to Core team",
  "type": "object",
  "required": [
    "escalation_id",
    "escalated_by",
    "escalated_at",
    "gate_id",
    "eval_id",
    "severity",
    "concern",
    "context"
  ],
  "additionalProperties": true,
  "properties": {
    "escalation_id": {
      "type": "string",
      "description": "Unique identifier for tracking this escalation",
      "pattern": "^ESC-\\d{4}-\\d{3}(-v\\d+)?$"
    },
    "escalated_by": {
      "type": "string",
      "description": "Extended team persona submitting this escalation (persona_id from TEAM.md)"
    },
    "escalated_at": {
      "type": "string",
      "description": "When this escalation was filed",
      "format": "date-time"
    },
    "gate_id": {
      "type": "string",
      "description": "Which gate this escalation applies to (from GATES.md)",
      "enum": [
        "pr-merge",
        "release-candidate",
        "release-approval",
        "content-publish",
        "customer-commitment",
        "production-deploy"
      ]
    },
    "eval_id": {
      "type": "string",
      "description": "Which eval surfaced this concern (eval filename)"
    },
    "severity": {
      "type": "string",
      "description": "Priority tier determining review SLA",
      "enum": [
        "P0",
        "P1",
        "P2"
      ]
    },
    "concern": {
      "type": "object",
      "description": "Core content describing the risk and evidence",
      "required": [
        "risk_prevented",
        "evidence",
        "stop_rule",
        "confidence"
      ],
      "additionalProperties": true,
      "properties": {
        "risk_prevented": {
          "type": "string",
          "description": "What bad outcome this escalation prevents"
        },
        "evidence": {
          "type": "array",
          "description": "Links, logs, test results proving concern validity",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "stop_rule": {
          "type": "string",
          "description": "What would satisfy this escalation (clear resolution criteria)"
        },
        "confidence": {
          "type": "string",
          "description": "How certain is escalator that concern is valid",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        }
      }
    },
    "context": {
      "type": "object",
      "description": "Background information helping Core team understand investigation depth",
      "required": [
        "investigation_summary"
      ],
      "additionalProperties": true,
      "properties": {
        "investigation_summary": {
          "type": "string",
          "description": "What Extended team already checked (proves homework was done)"
        },
        "related_escalations": {
          "type": "array",
          "description": "Prior escalation IDs on same topic",
          "items": {
            "type": "string",
            "pattern": "^ESC-\\d{4}-\\d{3}(-v\\d+)?$"
          }
        },
        "recommended_disposition": {
          "type": "string",
          "description": "Extended's suggestion (not binding)",
          "enum": [
            "approve",
            "deny",
            "need_more_info"
          ]
        }
      }
    }
  }
}
