{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://converge.zone/schemas/strategy_gate_execution.schema.json",
  "title": "Strategy Gate Execution",
  "description": "Schema for strategy gate execution records. Captures lens check results and gate decisions.",
  "type": "object",
  "required": ["fixture_id", "gate_id", "lens_pack_version", "artifact", "lens_results", "decision"],
  "properties": {
    "fixture_id": {
      "type": "string",
      "pattern": "^[a-z-]+\\.[a-z0-9-]+$",
      "description": "Unique identifier for this gate execution: <gate_id>.<scenario>"
    },
    "gate_id": {
      "type": "string",
      "enum": ["content-publish", "customer-commitment", "roadmap-promotion", "architecture-promotion", "funding-narrative"],
      "description": "Which strategy gate was executed"
    },
    "lens_pack_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+$",
      "description": "Version of lens pack definitions used"
    },
    "artifact": {
      "type": "object",
      "required": ["type", "ref", "summary"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["website", "contract", "roadmap", "architecture", "deck", "email", "sow", "press-release", "documentation"],
          "description": "Type of artifact being validated"
        },
        "ref": {
          "type": "string",
          "description": "Reference to artifact (URL, document ID, or file path)"
        },
        "summary": {
          "type": "string",
          "maxLength": 200,
          "description": "One-line summary of the artifact"
        }
      },
      "additionalProperties": false
    },
    "lens_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lens_result"
      },
      "description": "Results from each lens check executed"
    },
    "decision": {
      "type": "object",
      "required": ["outcome"],
      "properties": {
        "outcome": {
          "type": "string",
          "enum": ["PASS", "WARN", "STOP"],
          "description": "Final gate decision"
        }
      },
      "additionalProperties": false
    },
    "acknowledgment_ref": {
      "type": "string",
      "description": "Reference to acknowledgment record. Required if outcome == WARN."
    },
    "override_ref": {
      "type": "string",
      "description": "Reference to override record. Required if outcome == STOP and gate was overridden."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of gate execution"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "properties": {
              "outcome": { "const": "WARN" }
            }
          }
        }
      },
      "then": {
        "required": ["acknowledgment_ref"]
      }
    }
  ],
  "$defs": {
    "lens_result": {
      "type": "object",
      "required": ["check_id", "voice", "class", "severity", "summary"],
      "properties": {
        "check_id": {
          "type": "string",
          "pattern": "^[a-z]+\\.[a-z_]+\\.v\\d+$",
          "description": "Unique check identifier: <voice>.<check_name>.v<version>"
        },
        "voice": {
          "type": "string",
          "description": "Which strategic voice performed this check"
        },
        "class": {
          "type": "string",
          "enum": ["A", "B", "C"],
          "description": "Determinism class: A=deterministic, B=bounded, C=nondeterministic"
        },
        "severity": {
          "type": "string",
          "enum": ["PASS", "WARN", "STOP", "NOTE"],
          "description": "Check result severity"
        },
        "summary": {
          "type": "string",
          "maxLength": 500,
          "description": "One-line summary of the check result"
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "References to evidence supporting this result"
        },
        "remediation": {
          "type": "string",
          "description": "Suggested remediation if severity is WARN or STOP"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": { "severity": { "const": "STOP" } }
          },
          "then": {
            "properties": { "class": { "const": "A" } }
          }
        },
        {
          "if": {
            "properties": { "class": { "const": "C" } }
          },
          "then": {
            "properties": { "severity": { "const": "NOTE" } }
          }
        }
      ]
    }
  }
}
