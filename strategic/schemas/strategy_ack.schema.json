{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://converge.zone/schemas/strategy_ack.schema.json",
  "title": "Strategy WARN Acknowledgment",
  "description": "Schema for acknowledging WARN outcomes at strategy gates. Requires mitigation, counter-voice consultation, and explicit ownership.",
  "type": "object",
  "required": ["gate_id", "artifact_ref", "warnings_accepted", "counter_voice_consulted", "owner", "timestamp"],
  "properties": {
    "gate_id": {
      "type": "string",
      "enum": ["content-publish", "customer-commitment", "roadmap-promotion", "architecture-promotion", "funding-narrative"],
      "description": "Which strategy gate produced the warnings"
    },
    "artifact_ref": {
      "type": "string",
      "description": "Reference to the artifact that triggered warnings"
    },
    "warnings_accepted": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/warning_acceptance"
      },
      "description": "List of warnings being acknowledged"
    },
    "counter_voice_consulted": {
      "type": "object",
      "required": ["voice", "conclusion"],
      "properties": {
        "voice": {
          "type": "string",
          "description": "Which counter-voice was consulted"
        },
        "conclusion": {
          "type": "string",
          "maxLength": 500,
          "description": "One-line conclusion from counter-voice consultation"
        }
      },
      "additionalProperties": false,
      "description": "Counter-voice consultation is mandatory for all WARN acknowledgments"
    },
    "owner": {
      "type": "object",
      "required": ["name", "role"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of person accepting responsibility"
        },
        "role": {
          "type": "string",
          "description": "Role of person accepting responsibility"
        }
      },
      "additionalProperties": false
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of acknowledgment"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "warning_acceptance": {
      "type": "object",
      "required": ["check_id", "rationale", "mitigation"],
      "properties": {
        "check_id": {
          "type": "string",
          "pattern": "^[a-z]+\\.[a-z_]+\\.v\\d+$",
          "description": "Check ID being acknowledged"
        },
        "rationale": {
          "type": "string",
          "minLength": 10,
          "description": "Why this warning is acceptable now"
        },
        "mitigation": {
          "type": "string",
          "minLength": 10,
          "description": "How the risk is bounded or mitigated"
        }
      },
      "additionalProperties": false
    }
  }
}
